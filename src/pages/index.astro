---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout>
  <section class="projects-section">
    <h2 class="section-heading">Projects</h2>
    <ul class="project-cards">
      {projects.map(project => {
        const { name, tagline, appUrl, appLabel, githubUrl, relatedPosts } = project.data;
        const primaryHref = relatedPosts.length === 1
          ? `/posts/${relatedPosts[0]}/`
          : `/projects/${project.id}/`;
        return (
          <li class="project-card">
            <div class="project-card-body">
              <h3><a href={primaryHref}>{name}</a></h3>
              <p>{tagline}</p>
            </div>
            <div class="project-card-actions">
              {githubUrl && (
                <a href={githubUrl} class="icon-link" target="_blank" rel="noopener" aria-label={`${name} on GitHub`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                </a>
              )}
              <a href={primaryHref} class="btn btn-ghost btn-sm">Learn more</a>
              {appUrl && (
                <a href={appUrl} class="btn btn-primary btn-sm" target="_blank" rel="noopener">{appLabel ?? 'Open app'}</a>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  </section>

  <section class="post-list">
    <h2 class="section-heading">Posts</h2>
    <ul>
      {posts.map(post => {
        const formattedDate = post.data.date.toLocaleDateString('en-GB', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <li>
            <a href={`/posts/${post.id}/`}>
              <span class="post-title">{post.data.title}</span>
              <time class="post-date" datetime={post.data.date.toISOString()}>{formattedDate}</time>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
